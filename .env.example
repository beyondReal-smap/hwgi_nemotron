# ============================================================
# PersonaFit 환경변수 템플릿
# ============================================================
# 사용법: cp .env.example .env  → 실제 키 입력
# ============================================================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# --- Supabase ---
# 프로젝트 설정 → API에서 확인
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...        # 서버 전용 (백엔드에서만 사용)
SUPABASE_ANON_KEY=eyJhbGciOi...                # 클라이언트 가능 (RLS 적용)

# --- 포트 설정 ---
WEB_PORT=5101                                  # Next.js (외부 노출)
API_PORT=5102                                  # FastAPI (내부 전용)
API_INTERNAL_URL=http://127.0.0.1:5102         # Next.js rewrites가 프록시할 대상

# Next.js rewrites 사용 시 비워두기. 외부 호스트에서 직접 FastAPI 호출 시에만 설정.
NEXT_PUBLIC_API_BASE_URL=

# --- Kakao Maps JS SDK (시군구 분포 지도) ---
# https://developers.kakao.com/console/app → "JavaScript 키"
# 도메인 등록 필수: localhost (개발), 운영 호스트
# 미설정 시 지도는 안내 메시지로 대체되고 Top10 표만 표시
NEXT_PUBLIC_KAKAO_MAP_APPKEY=

# --- 백엔드 설정 ---
API_CORS_ORIGINS=http://localhost:5101         # Next.js만 허용

# 데이터셋 적재 시 사용
SAMPLE_TARGET_TOTAL=100000
